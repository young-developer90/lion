{
  "name": "lion-lang",
  "displayName": "Lion Language",
  "description": "Lion scripting language — syntax highlighting, snippets, and LSP support",
  "version": "0.2.0",
  "publisher": "lion-lang",
  "icon": "icon.ico",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Language Servers"],
  "activationEvents": ["onLanguage:lion"],
  "main": "./src/extension.js",
  "contributes": {
    "languages": [{
      "id": "lion",
      "aliases": ["Lion", "lion"],
      "extensions": [".lion"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "lion",
      "scopeName": "source.lion",
      "path": "./syntaxes/lion.tmLanguage.json"
    }],
    "snippets": [{
      "language": "lion",
      "path": "./snippets/lion.json"
    }]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
