// Panther GUI test
let root = panther.Leo("Panther Test", 400, 300);
let label = panther.Label(root, "Hello from Panther!");
panther.pack(label);
let btn = panther.Button(root, "Click me", func() {
    panther.config(label, "text", "Clicked!");
});
panther.pack(btn);
let entry = panther.Entry(root);
panther.pack(entry);
let get_btn = panther.Button(root, "Get text", func() {
    let val = panther.get(entry);
    panther.config(label, "text", val);
});
panther.pack(get_btn);
print("Panther GUI loaded, starting mainloop...");
panther.mainloop(root);
